{
	"compilerOptions": {
		"outDir": "libs",
		"rootDir": "./src",
		"allowJs": false,
		"allowSyntheticDefaultImports": true,
		"allowUnreachableCode": false,
		"allowUnusedLabels": false,
		"alwaysStrict": true,
		"declaration": true,
		"esModuleInterop": true,
		"module": "nodenext",
		"skipLibCheck": true,
		"sourceMap": false,
		"strict": true,
		"target": "esnext",
		"lib": [
			"DOM",
			"ES2022"
		]
	},
	"include": ["src"]
}
